{
  "name": "maestrobot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "agent:run": "tsx scripts/run-agent.ts",
    "persona:import": "tsx scripts/import-persona.ts",
    "stem:publish": "tsx scripts/publish-stem.ts",
    "plan:cleanup": "tsx scripts/cleanup-plans.ts",
    "studio": "pnpm --filter @maestrobot/studio dev",
    "samples:fetch": "tsx scripts/fetch-samples.ts",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
