# Providers — set only the ones you have keys for. The registry
# skips any that are missing, and agents fail loudly if their config
# names a provider that isn't wired.

# Fireworks — main compose rail (kimi-k2, llama-4, deepseek, qwen, etc.)
FIREWORKS_API_KEY=

# NVIDIA NIM — free tier, 40 rpm cap
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Groq — ultra-fast (~275 tok/s) for realtime murmurs
GROQ_API_KEY=

# DeepSeek direct — R1 reasoner, cache-hit input is ~$0.028/M
DEEPSEEK_API_KEY=

# DashScope (Alibaba Qwen family; opens door to Qwen2-Audio later)
DASHSCOPE_API_KEY=

# Arcee — direct to api.arcee.ai (Trinity family)
ARCEE_API_KEY=

# Apocalypse Radio integration
APOC_API_URL=https://apoc-api-production.up.railway.app
APOC_NOSTR_RELAY=wss://relay.apocalypseradio.xyz

# SQLite file for personas / stems / preferences / murmurs.
MAESTROBOT_DB_PATH=./maestrobot.db

# Where agent decision journals get written (one NDJSON per agent)
MAESTROBOT_JOURNAL_DIR=./journal
